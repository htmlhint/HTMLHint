{
  "name": "htmlhint.com",
  "version": "0.0.0",
  "private": true,
  "description": "The HTMLHint website - built with Astro Starlight",
  "homepage": "https://htmlhint.com",
  "bugs": {
    "url": "https://github.com/htmlhint/HTMLHint/issues"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/htmlhint"
  },
  "license": "MIT",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "start": "astro dev",
    "htmlhint": "npx htmlhint .",
    "htmlhint-report": "npx htmlhint . --format html",
    "htmlhint-sarif": "npx htmlhint . --format sarif",
    "pa11y-ci": "npx pa11y-ci https://htmlhint.com/",
    "stylelint": "npx stylelint@latest \"src/*.css\" --fix -f verbose"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.40.0",
    "astro": "^6.4.8",
    "sharp": "^0.34.5",
    "starlight-llms-txt": "^0.10.0"
  },
  "overrides": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3"
  },
  "devDependencies": {
    "stylelint-config-recommended": "^18.0.0"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "volta": {
    "node": "22.22.2"
  }
}
